<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="28sp"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- ===== ESP32 Connection ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/surface_dark"
            android:elevation="4dp"
            android:radius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔌 ESP32 Connection"
                    android:textSize="16sp"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="ESP32 IP Address">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etIpAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="192.168.4.1"
                        android:inputType="text"
                        android:textColor="@color/text_white" />

                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnSyncLamp"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔄 Sync Lamp"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/accent_blue" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ===== Screen Time Limit ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/surface_dark"
            android:elevation="4dp"
            android:radius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️ Screen Time Limit"
                    android:textSize="16sp"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvTimeLimitValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30 minutes"
                    android:textSize="14sp"
                    android:textColor="@color/accent_green"
                    android:layout_marginBottom="8dp" />

                <SeekBar
                    android:id="@+id/seekBarTimeLimit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:min="5"
                    android:max="120"
                    android:progress="30"
                    android:progressTint="@color/accent_green"
                    android:thumbTint="@color/accent_green" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ===== Blocked Apps ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/surface_dark"
            android:elevation="4dp"
            android:radius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱 Tracked Distracting Apps"
                    android:textSize="16sp"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvBlockedAppsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textSize="14sp"
                    android:textColor="@color/text_gray"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ===== Save Button ===== -->
        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💾 Save Settings"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:backgroundTint="@color/accent_green" />

    </LinearLayout>

</ScrollView>
