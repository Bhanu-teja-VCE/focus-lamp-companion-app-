<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus Lamp"
            android:textSize="28sp"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvEspIp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ESP32: 192.168.4.1"
            android:textSize="12sp"
            android:textColor="@color/text_gray"
            android:layout_marginBottom="24dp" />

        <!-- ===== Circular Progress Card ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/surface_dark"
            android:elevation="4dp"
            android:radius="16dp"
            android:padding="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's Screen Time"
                    android:textSize="14sp"
                    android:textColor="@color/text_gray"
                    android:layout_marginBottom="16dp" />

                <!-- Circular Progress -->
                <FrameLayout
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center">

                    <ProgressBar
                        android:id="@+id/progressScreenTime"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/circular_progress"
                        android:rotation="-90" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_gravity="center">

                        <TextView
                            android:id="@+id/tvDistractionTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 min"
                            android:textSize="32sp"
                            android:textColor="@color/accent_green"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTimeLimit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/ 30 min limit"
                            android:textSize="13sp"
                            android:textColor="@color/text_gray" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Limit Warning -->
                <TextView
                    android:id="@+id/tvLimitWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Screen time limit exceeded!"
                    android:textSize="14sp"
                    android:textColor="@color/warning_red"
                    android:visibility="gone"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ===== Monitoring Status Card ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/surface_dark"
            android:elevation="4dp"
            android:radius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvMonitoringStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚫ Monitoring Off"
                    android:textSize="16sp"
                    android:textColor="@color/text_white"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnToggleMonitoring"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Start Monitoring"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/accent_green" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ===== Focus Timer Button ===== -->
        <Button
            android:id="@+id/btnStartFocus"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🎯 Start Focus Timer"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:backgroundTint="@color/accent_blue"
            android:layout_marginBottom="16dp" />

        <!-- ===== Quick Stats Card ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/surface_dark"
            android:elevation="4dp"
            android:radius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center"
                android:weightSum="2">

                <!-- Total Focus Time -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Focus"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray" />

                    <TextView
                        android:id="@+id/tvTotalFocusTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0h 0m"
                        android:textSize="22sp"
                        android:textColor="@color/accent_green"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Completed Sessions -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sessions"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray" />

                    <TextView
                        android:id="@+id/tvCompletedSessions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textColor="@color/accent_blue"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
