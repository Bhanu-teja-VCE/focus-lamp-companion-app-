<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="80dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp">

        <!-- ========================================= -->
        <!--  SECTION 1: Virtual Lamp Status           -->
        <!-- ========================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="24dp"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FOCUS LAMP"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Large Lamp Glow Circle -->
            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp">

                <View
                    android:id="@+id/viewLampGlow"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_progress_track" />

                <TextView
                    android:id="@+id/tvLampIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="48sp"
                    android:layout_gravity="center" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvLampStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Within Limit"
                android:textSize="18sp"
                android:textColor="@color/accent_green"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvLampDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0m used of 30m limit"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- ========================================= -->
        <!--  SECTION 2: Set Waste Time Limit          -->
        <!-- ========================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set Your Screen Time Limit"
                android:textSize="15sp"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter the max time (minutes) you want to waste"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etWasteTimeLimit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_field"
                    android:hint="e.g. 135"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_white"
                    android:textSize="16sp"
                    android:paddingHorizontal="16dp"
                    android:inputType="number"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/btnSetLimit"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Set"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:paddingHorizontal="24dp"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvCurrentLimit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current limit: 30 min"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- ========================================= -->
        <!--  SECTION 3: Per-App Screen Time List      -->
        <!-- ========================================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="App Usage Today"
            android:textSize="17sp"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:paddingStart="4dp" />

        <LinearLayout
            android:id="@+id/layoutAppUsageList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>
