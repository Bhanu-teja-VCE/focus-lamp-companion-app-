<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutSessionRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/background_dark"
    android:padding="32dp">

    <!-- Glowing Background effect for Focus -->
    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:layout_marginBottom="48dp"
        android:background="@drawable/bg_card_dark"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvSessionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IN FOCUS"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25:00"
                android:textSize="64sp"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>
    </FrameLayout>

    <Button
        android:id="@+id/btnStopSession"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="Stop Session"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/accent_red"
        android:background="@drawable/bg_button_primary" />

</LinearLayout>
