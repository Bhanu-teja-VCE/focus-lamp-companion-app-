<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutSessionRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/focus_green"
    android:padding="32dp">

    <TextView
        android:id="@+id/tvSessionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stay Focused! 🧘"
        android:textSize="24sp"
        android:textColor="@color/text_white"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25:00"
        android:textSize="72sp"
        android:textColor="@color/text_white"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btnStopSession"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="Stop Session"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:backgroundTint="@color/warning_red" />

</LinearLayout>
