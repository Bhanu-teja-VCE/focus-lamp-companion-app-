<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== PERMISSIONS ===== -->
    <!-- Internet: To send HTTP signals to the ESP32 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Wi-Fi Control: To programmatically toggle Wi-Fi -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- Screen Time Tracking: To read which apps are open and for how long -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Foreground Service: To keep monitoring alive -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Notifications: Required on Android 13+ to show foreground service notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".FocusLampApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_lamp"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_lamp"
        android:supportsRtl="true"
        android:theme="@style/Theme.FocusLamp"
        tools:targetApi="34">

        <!-- Main Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground Service for Screen Time Monitoring -->
        <service
            android:name=".service.FocusMonitorService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

    </application>

</manifest>
